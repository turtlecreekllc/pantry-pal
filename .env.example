# Required for local run
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key
EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key
EXPO_PUBLIC_SPOONACULAR_API_KEY=your_spoonacular_api_key

# Stripe (subscription/paywall) - use test keys for local
EXPO_PUBLIC_STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_INDIVIDUAL_ANNUAL=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_FAMILY_MONTHLY=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_FAMILY_ANNUAL=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_50=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_150=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_400=price_xxx

# STRIPE_SECRET_KEY is NOT a client variable. It is a Supabase Edge Function
# secret only — set it via `supabase secrets set STRIPE_SECRET_KEY=sk_...`.
# Never prefix it with EXPO_PUBLIC_*: Expo inlines EXPO_PUBLIC_* vars into the
# shipped JS bundle, which would leak the Stripe secret to every client.

# Optional - features work without these (graceful fallback)
# EXPO_PUBLIC_INSTACART_PARTNER_ID=
# EXPO_PUBLIC_IMPACT_AFFILIATE_ID=
# EXPO_PUBLIC_REMOVE_BG_API_KEY=
# EXPO_PUBLIC_APPLE_SHARED_SECRET=
# EXPO_PUBLIC_APP_URL=dinner-plans://

# Product analytics (PostHog). Leave unset to disable instrumentation entirely;
# lib/analytics calls become silent no-ops without these. Host defaults to
# https://us.i.posthog.com when omitted.
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=
