# Required for local run
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe (subscription/paywall) - use test keys for local
EXPO_PUBLIC_STRIPE_PRICE_INDIVIDUAL_MONTHLY=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_INDIVIDUAL_ANNUAL=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_FAMILY_MONTHLY=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_FAMILY_ANNUAL=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_50=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_150=price_xxx
EXPO_PUBLIC_STRIPE_PRICE_TOKENS_400=price_xxx

# ----------------------------------------------------------------------------
# Provider secrets — NEVER prefix with EXPO_PUBLIC_*
#
# Expo inlines every EXPO_PUBLIC_* variable into the shipped JS bundle, which
# would leak the secret to any user who decompiles the IPA/APK. Set these as
# Supabase Edge Function secrets only:
#
#   supabase secrets set STRIPE_SECRET_KEY=sk_...
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set SPOONACULAR_API_KEY=...
#
# ANTHROPIC_API_KEY     -> consumed by supabase/functions/claude-proxy        (SEC-006)
# OPENAI_API_KEY        -> consumed by supabase/functions/openai-audio-proxy  (SEC-006)
# SPOONACULAR_API_KEY   -> consumed by supabase/functions/spoonacular-proxy   (SEC-006)
# ----------------------------------------------------------------------------

# Optional - features work without these (graceful fallback)
# EXPO_PUBLIC_INSTACART_PARTNER_ID=
# EXPO_PUBLIC_IMPACT_AFFILIATE_ID=
# EXPO_PUBLIC_REMOVE_BG_API_KEY=
# EXPO_PUBLIC_APPLE_SHARED_SECRET=
# EXPO_PUBLIC_APP_URL=dinner-plans://
