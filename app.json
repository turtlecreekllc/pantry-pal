{
  "expo": {
    "name": "Pantry Pal",
    "slug": "pantry-pal",
    "owner": "turtle-creek-llc",
    "version": "1.6.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "pantry-pal",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.turtlecreekllc.pantrypal",
      "associatedDomains": [
        "applinks:pantrypal.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Pantry Pal needs camera access to scan product barcodes",
        "NSCalendarsUsageDescription": "Pantry Pal needs calendar access to sync your meal plans",
        "NSRemindersUsageDescription": "Pantry Pal needs reminders access to set meal reminders",
        "NSHealthShareUsageDescription": "Pantry Pal needs access to write nutrition data to HealthKit.",
        "NSHealthUpdateUsageDescription": "Pantry Pal needs access to update nutrition data in HealthKit.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "25",
      "splash": {
        "backgroundColor": "#4CAF50",
        "resizeMode": "contain"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.turtlecreekllc.pantrypal",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.health.READ_NUTRITION",
        "android.permission.health.WRITE_NUTRITION"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "category": [
            "android.intent.category.DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        },
        {
          "action": "android.intent.action.VIEW",
          "category": [
            "android.intent.category.DEFAULT",
            "android.intent.category.BROWSABLE"
          ],
          "data": [
            {
              "scheme": "pantry-pal"
            }
          ]
        }
      ],
      "versionCode": 13
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Pantry Pal needs camera access to scan product barcodes"
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Pantry Pal needs calendar access to sync your meal plans",
          "remindersPermission": "Pantry Pal needs reminders access to set meal reminders"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#4CAF50"
        }
      ],
      [
        "react-native-health-connect",
        {
          "permissions": [
            "android.permission.health.READ_NUTRITION",
            "android.permission.health.WRITE_NUTRITION"
          ]
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "27c46aa7-c409-4f5b-b63d-db513cf5b493"
      }
    }
  }
}
